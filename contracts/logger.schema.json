{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Observex Log Record",
  "type": "object",
  "required": ["level", "message"],
  "properties": {
    "level": {
      "enum": ["debug", "info", "warn", "error"]
    },
    "message": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "request_id": {
      "type": "string"
    },
    "correlation_id": {
      "type": "string"
    },
    "fields": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
